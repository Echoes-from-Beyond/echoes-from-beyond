{
  "Type": "Chain",
  "Id": "Gk1_1",
  "Entries": [
    {
      "Id": "Standard",
      "Name": "Narrator",
      "Line": "And that's what you do. A 'conversation' that never even began comes to a screeching halt.",
      "UiPage": "Classic_Dialogue.ui",
      "UiFragment": "Classic_Dialogue_Fragment.ui"
    },
    {
      "Id": "Standard",
      "Name": "Narrator",
      "Line": "You notice more details about her: her real leaf woven into the bouquet on her head, the tacked-on claws on her hands as if she is an animal, the thorns scattered about her entire frame--",
      "UiPage": "Classic_Dialogue.ui",
      "UiFragment": "Classic_Dialogue_Fragment.ui"
    },
    {
      "Id": "Standard",
      "Name": "Narrator",
      "Line": "--her posture straightening in tandem with a frown on her face.",
      "UiPage": "Classic_Dialogue.ui",
      "UiFragment": "Classic_Dialogue_Fragment.ui"
    }
  ],
  "AdvanceText": "Continue",
  "End": {
    "Type": "Standard",
    "Line": {
      "Id": "Standard",
      "Text": "Are you done staring at me?"
    },
    "Name": {
      "Id": "Standard",
      "Text": "Goth Kweebec"
    },
    "UiPage": "Classic_Dialogue.ui",
    "UiFragment": "Classic_Dialogue_Fragment.ui",
    "Choices": [
      {
        "Id": "Standard",
        "Text": "I... don't know how to explain myself.",
        "Action": {
          "Id": "Advance",
          "Next": "Gk1_2A"
        }
      },
      {
        "Id": "Standard",
        "Text": "Hello to you, too.",
        "Action": {
          "Id": "Advance",
          "Next": "Gk1_2B"
        }
      },
      {
        "Id": "Standard",
        "Text": "I wasn't staring.",
        "Action": {
          "Id": "Advance",
          "Next": "Gk1_2C"
        }
      },
      {
        "Id": "Standard",
        "Text": "Says you.",
        "Action": {
          "Id": "Advance",
          "Next": "Gk1_2D"
        }
      },
      {
        "Id": "Standard",
        "Text": "Gaia almighty, you are *so* gorgeous.",
        "Action": {
          "Id": "Advance",
          "Next": "Gk1_2E"
        }
      },
      {
        "Id": "Standard",
        "Text": "[Meh. You don't like what you see.][Leave]",
        "Action": {
          "Id": "Composite",
          "Actions": [
            {
              "Id": "SetMetadata",
              "MetadataKey": "Gk_Relationship",
              "MetadataStoreKey": "GOTH_KWEEBEC",
              "Metadata": {
                "Id": "String",
                "Value": "Gk_Ignore"
              }
            },
            {
              "Id": "Close"
            }
          ]
        }
      }
    ]
  }
}
