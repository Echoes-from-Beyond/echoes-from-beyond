      "Text": "Narrator"
    },
    "UiPage": "Classic_Dialogue.ui",
    "UiFragment": "Classic_Dialogue_Fragment.ui",
    "Choices": [
      {
        "Id": "Standard",
        "Text": "It was just a compliment. I didn't mean to imply anything more than that.",
        "Action": {
          "Id": "Advance",
          "Next": "Gk1_2E-3A"
        }
      },
      {
        "Id": "Standard",
        "Text": "Whoa, hold up! I was saying that as one goth to another.",
