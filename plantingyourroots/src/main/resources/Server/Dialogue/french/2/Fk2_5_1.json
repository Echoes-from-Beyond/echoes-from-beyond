{
  "Type": "Standard",
  "Id": "Fk2_5_1",
  "Line": {
    "Id": "Select",
    "Default": {
      "Id": "Standard",
      "Text": "Mon ami, if I may ask, can you offer me a distraction ? Give me something to think about that is not mes pensées."
    },
    "MetadataKey": "Fk2_5_1",
    "Options": {
      "Fk2_5-L1": {
        "Id": "Standard",
        "Text": "What my home is, back in France ... it is peu difficile to talk about."
      },
      "Fk2_5-L2": {
        "Id": "Standard",
        "Text": "C'est très irritant."
      },
      "Fk2_5-L3": {
        "Id": "Standard",
        "Text": "--eh, maybe that is not a story for lunchtime."
      },
      "Fk2_5-L4": {
        "Id": "Standard",
        "Text": "Ah, I am sorry. I did not wish to imply that you would make the same error. It is just something that has plagued my life as of late."
      },
      "Fk2_5-L5": {
        "Id": "Standard",
        "Text": "Mon ami, that is exactly what I need a distraction from."
      }
    }
  },
