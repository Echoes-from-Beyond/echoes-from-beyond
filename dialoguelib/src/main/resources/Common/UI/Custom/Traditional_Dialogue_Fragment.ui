$C = "Common.ui";

Button #DialogueButton {
  Anchor: (Width: 1200);
  Padding: (Horizontal: 20, Vertical: 15);
  LayoutMode: Top;
  // there's a ClearButtonStyle but it causes an exception...
  Style: $C.@DefaultButtonStyle;
  Label #DialogueLabel {
    Style: (
      Wrap: true,
      FontSize: 23,
      TextColor: #ffffff,
      RenderBold: true
    );
  }
}
